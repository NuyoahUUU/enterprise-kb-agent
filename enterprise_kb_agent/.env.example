APP_NAME="企业知识库 Agent 平台"
APP_VERSION=1.0.0

# Local-first demo mode. Pull the model before running:
# ollama pull qwen3:4b
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Use lexical fallback when the SentenceTransformers model is not available.
EMBEDDING_FALLBACK=lexical

# Optional OpenAI-compatible providers.
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
#
# LLM_PROVIDER=qwen
# QWEN_API_KEY=
# QWEN_MODEL=qwen-plus
#
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# API Key 用于保护敏感操作端点（如 /operations/execute）。
# 开发模式不设置此项时允许所有请求通过。
# OPERATIONS_API_KEY=your-secret-key
